# =========================
# Environment variables
# =========================
.env
.env.local
.env.*.local

# Supabase local (if ever used)
supabase/.temp
supabase/.env

# =========================
# Node (optional future use)
# =========================
node_modules/

# =========================
# Logs
# =========================
*.log

# =========================
# OS / Editor files
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Local data / generated files
# =========================

# CSVs (never commit pipeline outputs)
*.csv

# Ignore JSON / GeoJSON by default
*.json
*.geojson

# =========================
# Allow committed project data
# =========================

# Allow data folder itself
!data/

# Allow GeoJSON inside data (your boundaries)
!data/*.geojson

# (Optional future)
# Allow specific JSON configs if you add them later:
!data/*.json
# !config/*.json

# =========================
# Snapshots / exports
# =========================
*_snapshot.txt

# =========================
# Apps Script
# =========================
.clasp.json

# =========================
# Build artifacts (future-proof)
# =========================
dist/
build/